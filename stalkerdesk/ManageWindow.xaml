<Window x:Class="stalkerdesk.ManageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zarządzanie komputerem"
        Height="460" Width="520"
        WindowStartupLocation="CenterScreen"
        Background="#0B1220">

    <Border Background="#0F1B33" CornerRadius="20" Padding="20">

        <StackPanel>

            <TextBlock x:Name="PcName"
                       Foreground="White"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,15"/>

            <Button Content="Wyłącz"
                    Click="Shutdown_Click"
                    Background="#EF4444"
                    Foreground="White"
                    Margin="0,5"/>

            <Button Content="Restart"
                    Click="Restart_Click"
                    Background="#FACC15"
                    Foreground="#111"
                    Margin="0,5"/>

            <Button Content="Zablokuj"
                    Click="Lock_Click"
                    Background="#3B82F6"
                    Foreground="White"
                    Margin="0,5"/>

            <!-- TIMER -->
            <TextBlock Text="Timer (minuty)"
                       Foreground="White"
                       Margin="0,20,0,5"/>

            <TextBox x:Name="TimerBox"
                     Background="#111C33"
                     Foreground="White"
                     Padding="8"
                     Margin="0,0,0,10"/>

            <Button Content="Ustaw timer"
                    Click="Timer_Click"
                    Background="#3B82F6"
                    Foreground="White"/>
            <Button Content="Podgląd ekranu"
        Background="#10B981"
        Foreground="White"
        Margin="0,10,0,0"
        Click="Screen_Click"/>

        </StackPanel>

    </Border>
</Window>