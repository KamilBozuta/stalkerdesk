<Window x:Class="stalkerdesk.ManageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zarządzanie komputerem"
        Height="320" Width="320"
        WindowStartupLocation="CenterScreen"
        Background="#0B1220">

    <Window.Resources>

        <!-- COLORS -->
        <SolidColorBrush x:Key="Danger" Color="#EF4444"/>
        <SolidColorBrush x:Key="Warning" Color="#FACC15"/>
        <SolidColorBrush x:Key="Info" Color="#3B82F6"/>
        <SolidColorBrush x:Key="Panel" Color="#0F1B33"/>
        <SolidColorBrush x:Key="Text" Color="#E5E7EB"/>

        <!-- BASE BUTTON -->
        <Style x:Key="BaseActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ACTIONS -->
        <Style x:Key="ShutdownButton" TargetType="Button"
               BasedOn="{StaticResource BaseActionButton}">
            <Setter Property="Background" Value="{StaticResource Danger}"/>
        </Style>

        <Style x:Key="RestartButton" TargetType="Button"
               BasedOn="{StaticResource BaseActionButton}">
            <Setter Property="Background" Value="{StaticResource Warning}"/>
            <Setter Property="Foreground" Value="#111827"/>
        </Style>

        <Style x:Key="LockButton" TargetType="Button"
               BasedOn="{StaticResource BaseActionButton}">
            <Setter Property="Background" Value="{StaticResource Info}"/>
        </Style>

    </Window.Resources>

    <Border Background="{StaticResource Panel}"
            CornerRadius="18"
            Padding="20"
            Margin="10">

        <StackPanel>

            <TextBlock x:Name="PcName"
                       Foreground="{StaticResource Text}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,0,0,20"
                       Text="Komputer"/>

            <Button Content="Wyłącz komputer"
                    Click="Shutdown_Click"
                    Style="{StaticResource ShutdownButton}"/>

            <Button Content="Restartuj"
                    Click="Restart_Click"
                    Style="{StaticResource RestartButton}"/>

            <Button Content="Zablokuj"
                    Click="Lock_Click"
                    Style="{StaticResource LockButton}"/>

        </StackPanel>

    </Border>

</Window>
