<Window x:Class="stalkerdesk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StalkerDesk - Admin Panel" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#1E1E1E">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3E3E42"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- MENU -->
        <Border Background="#252526" Grid.Column="0" CornerRadius="0,15,15,0">
            <StackPanel Margin="10">
                <TextBlock Text="STALKER DESK" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,20,0,40"/>

                <Button Content="Dashboard" Style="{StaticResource MenuButtonStyle}"/>
                <Button Content="Komputery" Style="{StaticResource MenuButtonStyle}"/>
                <Button Content="Harmonogram" Style="{StaticResource MenuButtonStyle}"/>
                <Button Content="Ustawienia" Style="{StaticResource MenuButtonStyle}" Margin="0,200,0,0"/>
            </StackPanel>
        </Border>

        <!-- GŁÓWNY PANEL -->
        <Grid Grid.Column="1" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Lista komputerów w sieci"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="SemiBold"/>

            <Border Grid.Row="1" Background="#2D2D30" CornerRadius="15" Padding="15" Margin="0,20,0,0">
                <DataGrid ItemsSource="{Binding Computers}"
                          Background="Transparent"
                          BorderThickness="0"
                          Foreground="White"
                          RowBackground="#333337"
                          AlternatingRowBackground="#3E3E42"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          GridLinesVisibility="None">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nazwa" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Adres IP" Binding="{Binding IP}" Width="*"/>

                        <DataGridTemplateColumn Header="Akcje" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Zarządzaj"
                                            Click="Manage_Click"
                                            Background="#007ACC"
                                            Foreground="White"
                                            Padding="5,2"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Window>
 
